{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": "./src",
    "outDir": "./dist",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["jest", "node"]
  },
   "include": ["src/**/*"],
  "exclude": [
    "node_modules", 
    "dist", 
    "byte-to-bite-frontend",
    "byte-to-bite-frontend/**/*"
  ]
}